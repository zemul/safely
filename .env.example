# ============================================================
# safely 项目环境变量配置模板
# 复制此文件为 .env 并填入实际值，切勿提交 .env 到版本控制
# ============================================================

# === 阿里云短信 ===
ALIYUN_ACCESS_KEY_ID=your_access_key_id
ALIYUN_ACCESS_KEY_SECRET=your_access_key_secret

# === 云端后台数据库 (anbao/videoIO 模块共享) ===
ANBAO_DB_URL=jdbc:mysql://localhost:3306/anbao?characterEncoding=utf-8
ANBAO_DB_USERNAME=anbao_app
ANBAO_DB_PASSWORD=your_strong_password_here

# === RabbitMQ (云端 anbao/videoIO 模块) ===
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=anbao_mq
RABBITMQ_PASSWORD=your_mq_password_here
RABBITMQ_VHOST=/

# === 边缘端配置 ===
BASE_SERVER=https://your-server-domain:8080/
REDIS_HOST=localhost
REDIS_PORT=6379
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DB=py3
MYSQL_USERNAME=edge_app
MYSQL_PASSWORD=your_edge_db_password
MQ_HOST=your-mq-host
MQ_PORT=5672
MQ_USERNAME=edge_mq
MQ_PASSWORD=your_edge_mq_password

# === 设备端 API Key（云端和边缘端共享） ===
DEVICE_API_KEY=your-strong-random-api-key-here

# === MQ 消息签名密钥（可选，默认使用 DEVICE_API_KEY） ===
MQ_SIGNING_SECRET=your-mq-signing-secret-here

# === Redis 密码 ===
REDIS_PASSWORD=your_redis_password

# === CORS 配置 ===
CORS_ALLOWED_ORIGINS=https://your-frontend-domain.com

# === ARIMA 预测模块数据库 ===
ANBAO_DB_HOST=localhost
ANBAO_DB_NAME=anbao
# ANBAO_DB_USERNAME / ANBAO_DB_PASSWORD 同上
