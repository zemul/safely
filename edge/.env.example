# 边缘端环境变量

# 云端地址
BASE_SERVER=http://你的云端IP:8080/

# 数据库（本地）
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DB=py3
MYSQL_USERNAME=edge_app
MYSQL_PASSWORD=your_password

# RabbitMQ（连接云端）
MQ_HOST=你的云端IP
MQ_PORT=5672
MQ_USERNAME=anbao_mq
MQ_PASSWORD=your_mq_password

# API Key（与云端一致）
DEVICE_API_KEY=与云端相同的key

# MQ 签名密钥（与云端一致）
MQ_SIGNING_SECRET=与云端相同的secret

# FCHD 模型路径（可选，默认用 sparse/checkpoints/head_detector_final）
# FCHD_MODEL_PATH=/app/sparse/checkpoints/head_detector_final
